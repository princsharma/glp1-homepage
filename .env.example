# .env.example — committed template. NEVER put real secrets here.
# Copy this file to `.env.local` (preferred) or `.env`, then fill in values.
#
# Next.js loads these in order (later overrides earlier):
#   .env  →  .env.local  →  .env.{development,production}  →  .env.{...}.local
# Use `.env.local` for personal/dev overrides — it is gitignored by default.

# ─── Cloudinary ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=
NEXT_PUBLIC_CLOUDINARY_API_KEY=
NEXT_PUBLIC_CLOUDINARY_API_SECRET=
NEXT_PUBLIC_CLOUDINARY_UPLOAD_PRESET=

# ─── Gemini ─────────────────────────────────────────────────────────────────
GEMINI_API_KEY=

# ─── Stripe ─────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_RESTRICTED_KEY=

# ─── Firebase (Web SDK) ─────────────────────────────────────────────────────
# Public identifiers — safe to ship to browser. Security is enforced by
# Firebase Security Rules. Get these from:
#   Firebase Console → Project settings → General → Your apps → Web app → SDK setup.
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=
NEXT_PUBLIC_FIREBASE_ANALYTICS_ENABLED=
